# Phoenix
PHOENIX_BASE_URL=http://127.0.0.1:6006
PHOENIX_API_KEY=
PHOENIX_TOKEN=
PHOENIX_PROJECT_NAME=tracelitmus-demo
PHOENIX_DATASET_NAME=tracelitmus-demo-dataset
PHOENIX_SPACE_ID=

# Phoenix MCP
PHOENIX_MCP_COMMAND=npx
PHOENIX_MCP_PACKAGE=@arizeai/phoenix-mcp@latest

# Gemini / Google
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_GENAI_MODEL=gemini-2.5-flash
TRACE_LITMUS_ENABLE_GEMINI=false

# App
TRACE_LITMUS_DEFAULT_SOURCE=offline
TRACE_LITMUS_DEFAULT_PROJECT=demo
TRACE_LITMUS_REPORT_DIR=reports
